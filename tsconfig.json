{
  "compilerOptions": {
    // Environment
    "lib":             ["ESNext"],
    "target":          "ESNext",
    "module":          "Preserve",
    "moduleDetection": "force",

    // Paths
    "rootDir": ".",
    "outDir":  "./dist",

    // Bundler mode (Bun)
    // noEmit: true → tsc is for type-checking only
    // bun build handles actual compilation → dist/
    "moduleResolution":           "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax":       true,
    "noEmit":                     true,

    // Types
    "types":        ["bun-types"],
    "skipLibCheck": true,

    // Strictness
    "strict":                     true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride":         true,
    "noUnusedLocals":             false,
    "noUnusedParameters":         false,

    // Extras
    "resolveJsonModule": true,
    "esModuleInterop":   true,
    "allowJs":           false
  },
  "include": ["src/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist"]
}
